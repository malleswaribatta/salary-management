{
  "tasks": {
    "dev": "deno run -A --env=.env --watch main.ts",
    "db:generate": "deno run -A --env=.env npm:prisma generate",
    "db:push": "deno run -A --env=.env npm:prisma db push",
    "db:pull": "deno run -A --env=.env npm:prisma db pull",
    "db:migrate": "deno run -A --env=.env npm:prisma migrate dev --name init",
    "db:seed": "deno run -A --env=.env npm:prisma db seed",
    "db:reset": "deno run -A --env=.env npm:prisma migrate reset",
    "db:status": "deno run -A --env=.env npm:prisma migrate status"
  },
  "imports": {
    "@hono/hono": "jsr:@hono/hono@^4.12.24",
    "@prisma/adapter-pg": "npm:@prisma/adapter-pg@^7.0.0",
    "@prisma/client": "npm:@prisma/client@^7.0.0",
    "prisma": "npm:prisma@^7.0.0",
    "@std/assert": "jsr:@std/assert@1",
    "zod": "npm:zod@^4.4.3"
  },
  "nodeModulesDir": "auto",
  "compilerOptions": {
    "lib": ["deno.window"],
    "types": ["node"]
  }
}
